import bebidas.*
import tito.*

describe "tito consume 10 de whisky " {
  test "tito consume 10 de whisky y su sustancia actual es whisky" {
    tito.consumir(10, whisky)
    assert.equals(whisky, tito.sustanciaActual())
  }


   test "tito consume 10 de whisky y su dosis consumida es 10" {
    tito.consumir(10, whisky)
    assert.equals(10, tito.dosisConsumida())
  }


}


